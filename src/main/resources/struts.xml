<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <package name="default" namespace="/" extends="struts-default">

        <action name="order-list" class="com.danilo.lima.actions.OrderAction" method="orderList">
            <result name="orderList">/order-list.jsp</result>
        </action>

        <action name="order-form" class="com.danilo.lima.actions.OrderAction" method="orderForm">
            <result name="orderForm">/create.jsp</result>
        </action>

        <action name="order-create" class="com.danilo.lima.actions.OrderAction" method="orderCreate">
            <result name="orderCreate" type="redirectAction">
                order-list
            </result>
        </action>

    </package>

</struts>